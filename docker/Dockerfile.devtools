FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    clang \
    clang-tools \
    lld \
    llvm \
    make \
    cmake \
    ninja-build \
    python3 \
    python3-pip \
    git \
    ca-certificates \
    cscope \
    exuberant-ctags \
    bear \
    ripgrep \
    jq \
    file \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

CMD ["bash"]
